<mxfile host="app.diagrams.net">
  <diagram name="Опрос результата выполнения" id="polling">
    <mxGraphModel dx="1434" dy="844" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Начало -->
        <mxCell id="start" value="Начало" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="40" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Инициализация счетчика -->
        <mxCell id="step1" value="Установить счетчик попыток на 0" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="140" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Проверка лимита попыток -->
        <mxCell id="check1" value="Счетчик меньше 30?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="240" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Ошибка таймаута -->
        <mxCell id="error1" value="Вернуть ошибку: превышено время ожидания" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Отправка запроса -->
        <mxCell id="step2" value="Отправить запрос на сервер Judge0" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="380" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Проверка успешности запроса -->
        <mxCell id="check2" value="Запрос выполнен успешно?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="480" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Ошибка запроса -->
        <mxCell id="error2" value="Вернуть ошибку: не удалось получить данные" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="500" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Получение ответа -->
        <mxCell id="step3" value="Получить ответ от сервера" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="620" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Проверка статуса выполнения -->
        <mxCell id="check3" value="Код выполнен?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="720" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Ожидание -->
        <mxCell id="step4" value="Подождать 100 миллисекунд" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="740" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Увеличение счетчика -->
        <mxCell id="step5" value="Увеличить счетчик попыток на 1" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="840" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Декодирование результата -->
        <mxCell id="step6" value="Расшифровать результат выполнения" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="860" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Формирование ответа -->
        <mxCell id="step7" value="Сформировать итоговый результат" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="960" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Конец -->
        <mxCell id="end" value="Конец" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="1060" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Стрелки -->
        <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="start" target="step1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step1" target="check1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow3" value="Нет" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="check1" target="error1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="error1" target="end">
          <mxGeometry relative="1" as="geometry"/>
