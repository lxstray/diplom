<mxfile host="app.diagrams.net">
  <diagram name="Ограничение частоты запросов" id="rate-limit">
    <mxGraphModel dx="1434" dy="844" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Начало -->
        <mxCell id="start" value="Начало" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="40" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Получение текущего времени -->
        <mxCell id="step1" value="Получить текущее время" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="140" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Поиск записи пользователя -->
        <mxCell id="step2" value="Найти запись пользователя в памяти" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="240" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Проверка существования записи -->
        <mxCell id="check1" value="Запись существует и не истекла?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="340" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Создание нового окна -->
        <mxCell id="step3" value="Создать новое временное окно на 1 минуту" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Разрешить запрос (новое окно) -->
        <mxCell id="step4" value="Разрешить запрос, осталось 9 попыток" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="480" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Проверка лимита -->
        <mxCell id="check2" value="Достигнут лимит 10 запросов?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="500" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- Отказ -->
        <mxCell id="step5" value="Отказать в запросе, показать время ожидания" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="520" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Увеличить счетчик -->
        <mxCell id="step6" value="Увеличить счетчик запросов на 1" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="660" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Разрешить запрос -->
        <mxCell id="step7" value="Разрешить запрос, показать остаток попыток" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="760" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Конец -->
        <mxCell id="end" value="Конец" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="860" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Стрелки -->
        <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="start" target="step1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step2" target="check1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow4" value="Нет" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="check1" target="step3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step4" target="end">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow7" value="Да" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="check1" target="check2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow8" value="Да" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="check2" target="step5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step5" target="end">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow10" value="Нет" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="check2" target="step6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step6" target="step7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="arrow12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="step7" target="end">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
